@code {
    [Parameter] public string Title { get; set; } = "Balance";
    [Parameter] public double Amount { get; set; }
    [Parameter] public string Icon { get; set; } = "fa-wallet";
}
<div class="card balance-card">
    <i class="@Icon"></i>
    <h3>@Title</h3>
    <p>@Amount.ToString("C")</p>
</div>