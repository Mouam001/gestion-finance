@page "/register"
@using GestionWebAPP.Services
@using Common.Requests

<Div Margin="Margin.IsAuto.OnX" Width="Width.Is50">
    <Heading Size="HeadingSize.Is2" Margin="Margin.Is3.FromBottom" TextAlignment="TextAlignment.Center">
        Create an account
    </Heading>

    <Card Shadow="Shadow.Default">
        <CardBody>
            <Form OnValidSubmit="OnSubmit">
                <Field>
                    <FieldLabel>
                        Your Email
                    </FieldLabel>
                    <FieldBody>
                        <TextEdit @bind-Value="Email" Placeholder="name@blazorise.com" Role="TextRole.Email" />
                    </FieldBody>
                </Field>
                <Field>
                    <FieldLabel>
                        Password
                    </FieldLabel>
                    <FieldBody>
                        <TextEdit @bind-Value="Password" Placeholder="********" Role="TextRole.Password" autocomplete="new-password" />
                    </FieldBody>
                </Field>
                <Field>
                    <FieldLabel>
                        Confirm Password
                    </FieldLabel>
                    <FieldBody>
                        <TextEdit @bind-Value="ConfirmPassword" Placeholder="********" Role="TextRole.Password" autocomplete="new-password" />
                    </FieldBody>
                </Field>
                <Field Flex="Flex.JustifyContent.Between">
                    <Check @bind-Value="TermsAccepted" TValue="bool">
                        I accept the <Anchor To="#" TextColor="TextColor.Primary">Terms and Conditions</Anchor>
                    </Check>
                </Field>
                <Field>
                    <Button Color="Color.Primary" Block>
                        Create an account
                    </Button>
                </Field>
                <Field>
                    Already have an account? <Anchor To="/login" TextColor="TextColor.Primary">Login here</Anchor>
                </Field>
            </Form>
        </CardBody>
    </Card>
</Div>

@code {
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private string ConfirmPassword { get; set; } = "";
    private bool TermsAccepted { get; set; } = false;

    [Inject] private AuthService AuthService { get; set; }
    [Inject] private NavigationManager Navigation { get; set; }

    private async Task OnSubmit()
    {
        if (Password != ConfirmPassword)
        {
            Console.WriteLine("Passwords do not match");
            return;
        }

        var registerRequest = new RegisterRequest
        {
            Email = Email,
            Password = Password
        };

        var isSuccess = await AuthService.Register(registerRequest);

        if (isSuccess)
        {
            // Redirige vers la page de connexion ou l'accueil après une inscription réussie
            Navigation.NavigateTo("/login");
        }
        else
        {
            // Gérer l'échec de l'inscription (afficher un message d'erreur par exemple)
            Console.WriteLine("Registration failed");
        }
    }
}
