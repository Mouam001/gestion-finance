<div class="card red">
    <h4>🧾 Dépenses</h4>
    <p class="amount">@Amount.ToString("C")</p>
    @if (IsObpUser)
    {
        <p class="muted">Dépenses bancaires synchronisées avec OBP</p>
    }
    else
    {
        <p class="muted">Catégorie principale: @MainCategory</p>
    }
</div>

@code {
    [Parameter] public decimal Amount { get; set; }
    [Parameter] public string MainCategory { get; set; }
    [Parameter] public bool IsObpUser { get; set; }
}