@using Common.DTO
@using GestionWebAPP.Services
@inject TransactionApiService TransactionService
@inject AuthStateProvider AuthStateProvider
@inject HttpClient Http
@inject IJSRuntime JS
@code
{
    [Parameter] public bool IsObpUser { get; set; }
    private bool formVisible = false;

    private TransactionDto newTransaction = new()
    {
        PostedDate = DateTime.Today,
        CompletedDate = DateTime.Today
    };

    private void ShowForm() => formVisible = true;

    private void HideForm()
    {
        formVisible = false;
        newTransaction = new TransactionDto
        {
            PostedDate = DateTime.Today,
            CompletedDate = DateTime.Today
        };
        StateHasChanged();
    }

    [Parameter] public EventCallback OnTransactionCreated { get; set; }

    private async Task SubmitTransaction()
    {
        var request = new CreateTransactionRequest
        {
            Description = newTransaction.Description,
            Amount = newTransaction.Amount,
            Currency = newTransaction.Currency?.ToString(),
            Type = newTransaction.Type?.ToString(),
            Category = newTransaction.Category?.ToString(),
            PostedDate = newTransaction.PostedDate.Value,
            CompletedDate = newTransaction.CompletedDate.Value
        };

        var token = await AuthStateProvider.GetTokenAsync();
        var result = await TransactionService.CreateTransactionAsync(request, token);

        if (result.Success)
        {
            Console.WriteLine("Transaction enregistrée avec succès");
            HideForm();
            await OnTransactionCreated.InvokeAsync();
        }
        else
        {
            Console.WriteLine($"Erreur lors de l'enregistrement : {result.ErrorMessage}");
        }
    }

    private void OnOverlayClick()
    {
        HideForm();
    }
    
    private DateTime startDate = DateTime.Today.AddDays(-30);
    private DateTime endDate = DateTime.Today;

    private async Task DownloadReport()
    {
        if (startDate > endDate)
        {
            Console.WriteLine("❌ La date de début ne peut pas être après la date de fin.");
            return;
        }

        var url = $"/api/transaction/ExportTransactions?start={startDate:yyyy-MM-ddTHH:mm:ss}&end={endDate:yyyy-MM-ddTHH:mm:ss}";

        try
        {
            var response = await Http.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var pdfBytes = await response.Content.ReadAsByteArrayAsync();
                var base64 = Convert.ToBase64String(pdfBytes);
                var fileName = $"transactions_{startDate:yyyyMMdd}_{endDate:yyyyMMdd}.pdf";
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, fileName);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Erreur lors du téléchargement : {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Exception lors du téléchargement : {ex.Message}");
        }
    }


}

@if (!IsObpUser)
{
    <div class="text-end mb-3">
        <button class="btn btn-primary me-2" @onclick="ShowForm">➕ Ajouter une transaction</button>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <label>Date de début</label>
            <InputDate @bind-Value="startDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label>Date de fin</label>
            <InputDate @bind-Value="endDate" class="form-control" />
        </div>
        <div class="col-md-3 align-self-end">
            <button class="btn btn-outline-secondary" @onclick="DownloadReport">📥 Télécharger le PDF</button>
        </div>
    </div>

@if (formVisible)
{
    <div class="modal-overlay fade-in" @onclick="OnOverlayClick">
        <div class="modal-content" @onclick:stopPropagation>
            <EditForm Model="@newTransaction" OnValidSubmit="SubmitTransaction">
                <DataAnnotationsValidator />
                
                <div class="mb-3">
                    <label class="form-label">Type</label>
                    <InputSelect class="form-control" @bind-Value="newTransaction.Type">
                        <option value="">-- Sélectionner --</option>
                        @foreach (var t in Enum.GetValues<TransactionType>())
                        {
                            <option value="@t">@t.GetDisplayName()</option>
                        }
                    </InputSelect>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Catégorie</label>
                    <InputSelect class="form-control" @bind-Value="newTransaction.Category">
                        <option value="">-- Sélectionner --</option>
                        @foreach (var c in Enum.GetValues<TransactionCategory>())
                        {
                            <option value="@c">@c.GetDisplayName()</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <InputText class="form-control" @bind-Value="newTransaction.Description" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Montant</label>
                    <InputNumber class="form-control" @bind-Value="newTransaction.Amount" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Devise</label>
                    <InputSelect class="form-control" @bind-Value="newTransaction.Currency">
                        <option value="">-- Sélectionner --</option>
                        @foreach (var currency in Enum.GetValues<CurrencyCode>())
                        {
                            <option value="@currency">@currency.GetDisplayName()</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">Date d'envoi</label>
                    <InputDate class="form-control" @bind-Value="newTransaction.PostedDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Date de traitement</label>
                    <InputDate class="form-control" @bind-Value="newTransaction.CompletedDate" />
                </div>

                <button type="submit" class="btn btn-success">💾 Enregistrer</button>
                <button type="button" class="btn btn-secondary ms-2" @onclick="HideForm">❌ Annuler</button>
            </EditForm>
        </div>
    </div>
}
}
