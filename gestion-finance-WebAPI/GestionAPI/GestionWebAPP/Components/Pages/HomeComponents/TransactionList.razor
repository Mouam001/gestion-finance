@code {
    private List<Transaction> Transactions = new()
    {
        new Transaction { Date = DateTime.Now, Amount = 50.0, Description = "Restaurant" },
        new Transaction { Date = DateTime.Now.AddDays(-1), Amount = 100.0, Description = "Shopping" }
    };
}
<ul>
    @foreach (var transaction in Transactions)
    {
        <li>@transaction.Date.ToShortDateString() - @transaction.Description: @transaction.Amount.ToString("C")</li>
    }
</ul>

@code {
    public class Transaction
    {
        public DateTime Date { get; set; }
        public double Amount { get; set; }
        public string Description { get; set; } = string.Empty;
    }
}