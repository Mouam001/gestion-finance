@page "/"
@layout MainLayout

@using Microsoft.AspNetCore.Components.Authorization
@using GestionWebAPP.Components.Pages.HomeComponents
@using GestionWebAPP.Services
@using Common.DTO
@using GestionWebAPP.Components.Layout

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthStateProvider AuthStateProvider
@inject TransactionApiService TransactionService
@inject UserApiService UserService

<link href="style/dashboard.css" rel="stylesheet" />

@if (isUserAuthenticated)
{
    <h2>Tableau de bord</h2>
    <div class="dashboard p-4">
        <div class="cards-container">
            <BalanceCard Amount="@currentBalance" Variation="+5%" />
            <IncomeCard Amount="@totalIncome" Sources="@incomeCount" Average="@averageIncome" />
            <ExpenseCard Amount="@totalExpense" MainCategory="Loisirs" />
        </div>

        <div class="grid-two">
            <ExpensesChart Title="📊 Répartition des dépenses" />
            <TransactionList Transactions="@transactions" />
        </div>
        <div class="row align-items-center mb-4">
            <div class="col-md-6">
                <SavingGoal Goal="Vacances été" AmountSaved="300 €" GoalAmount="1 000 €" Progress="30" />
            </div>
            <div class="col-md-6">
                <DashboardActions OnTransactionCreated="ReloadTransactionsAsync" />
            </div>
        </div>
    </div>
}
else
{
    <p>Redirection vers la page de connexion...</p>
}

@code {
    private bool isUserAuthenticated;
    private bool initialized = false;

    private List<TransactionDto> transactions = new();

    private decimal userBalanceInit = 0;
    private decimal currentBalance = 0;

    private decimal totalIncome = 0;
    private int incomeCount = 0;
    private decimal averageIncome = 0;

    private decimal totalExpense = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !initialized)
        {
            initialized = true;

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            isUserAuthenticated = user.Identity?.IsAuthenticated ?? false;

            if (!isUserAuthenticated)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            try
            {
                var token = await AuthStateProvider.GetTokenAsync();

                // Récupération des infos utilisateur
                var currentUser = await UserService.GetCurrentUserAsync(token);
                userBalanceInit = Convert.ToDecimal(currentUser?.BalanceInit ?? 0);


                // Récupération des transactions
                transactions = await TransactionService.GetUserTransactionsAsync(token);

                // Traitement des données
                var incomes = transactions.Where(t => t.Amount > 0).ToList();
                var expenses = transactions.Where(t => t.Amount < 0).ToList();

                totalIncome = incomes.Sum(t => t.Amount);
                incomeCount = incomes.Count;
                averageIncome = incomeCount > 0 ? totalIncome / incomeCount : 0;

                totalExpense = expenses.Sum(t => Math.Abs(t.Amount));

                // 💰 Solde actuel
                currentBalance = userBalanceInit + totalIncome - totalExpense;
            }
            catch (Exception ex)
            {
                Console.WriteLine("Erreur : " + ex.Message);
            }

            StateHasChanged();
        }
    }

    private async Task ReloadTransactionsAsync()
    {
        var token = await AuthStateProvider.GetTokenAsync();
        transactions = await TransactionService.GetUserTransactionsAsync(token);

        // Recalcul après ajout de transaction
        var incomes = transactions.Where(t => t.Amount > 0).ToList();
        var expenses = transactions.Where(t => t.Amount < 0).ToList();

        totalIncome = incomes.Sum(t => t.Amount);
        incomeCount = incomes.Count;
        averageIncome = incomeCount > 0 ? totalIncome / incomeCount : 0;

        totalExpense = expenses.Sum(t => Math.Abs(t.Amount));
        currentBalance = userBalanceInit + totalIncome - totalExpense;

        StateHasChanged();
    }
}
