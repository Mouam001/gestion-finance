@page "/login"
@using System.ComponentModel.DataAnnotations
@using GestionWebAPP.Services
@using Common.Requests
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="container">
    <h2>Sign in to your account</h2>

    <form id="loginForm" @onsubmit="OnSubmit">
        <div class="input-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" @bind="LoginModel.Email" placeholder="name@example.com">
            @if (!string.IsNullOrEmpty(EmailError))
            {
                <span class="error-message">@EmailError</span>
            }
        </div>

        <div class="input-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" @bind="LoginModel.Password" placeholder="********">
            @if (!string.IsNullOrEmpty(PasswordError))
            {
                <span class="error-message">@PasswordError</span>
            }
        </div>
        
        <!-- Checkbox for user OBP -->
        <div class="input-group">
            <label>
                <input type="checkbox" id="isOPB" @bind="LoginModel.IsObpUser">
                Connexion with Open Bank Project
            </label>
        </div>

        <div class="options">
            <label>
                <input type="checkbox" id="rememberMe" @bind="LoginModel.RememberMe">
                Remember me
            </label>
            <a href="#">Forgot your password?</a>
        </div>

        <button class="loginbutton" type="submit">Sign in</button>

        @if (!string.IsNullOrEmpty(LoginError))
        {
            <div class="error-message">@LoginError</div>
        }

        <p class="register-link">Don’t have an account yet? <a href="/register">Sign up</a></p>
    </form>
</div>

@code {
    private ModelLogin LoginModel { get; set; } = new();
    private string EmailError = "";
    private string PasswordError = "";
    private string LoginError = "";

    private async Task OnSubmit()
    {
        EmailError = PasswordError = LoginError = "";
        
        if (string.IsNullOrWhiteSpace(LoginModel.Email))
            EmailError = "Email is required.";
        if (string.IsNullOrWhiteSpace(LoginModel.Password))
            PasswordError = "Password is required.";
        if (!string.IsNullOrEmpty(EmailError) || !string.IsNullOrEmpty(PasswordError))
            return;

        if (LoginModel.IsObpUser)
        {
            //Connexion avec Open Bank Project
            try
            {
                var response = await Http.PostAsJsonAsync("api/obp/loginOPB", new
                {
                    UsernameOPB = LoginModel.Email,
                    PasswordOPB = LoginModel.Password
                });

                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<ObpLoginResponse>();
                    if (!string.IsNullOrEmpty(result?.Token))
                    {
                        await LocalStorage.SetItemAsync("obpToken", result.Token);
                        await LocalStorage.SetItemAsync("isObpAuthenticated", "true");
                        Navigation.NavigateTo("/home-obp");
                    }
                    else
                    {
                        LoginError = "Token OBP is null or empty.";
                    }
                }
                else
                {
                    LoginError = "Identifiants OBP invalides";
                }
            }
            catch (Exception ex)
            {
                LoginError = $" Erreur lors de la connexion avec OBP : {ex.Message}";
            }
        }
        // Connexion normale
        else
        {
            var loginRequest = new LoginRequest
            {
                Email = LoginModel.Email,
                Password = LoginModel.Password,
            };
            var isSucess = await AuthService.Login(loginRequest);
            if (isSucess)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                LoginError = "Invalid email or password.";
            }
        }
    }

    public class ModelLogin
    {
        [Required(ErrorMessage = "Email is required")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; } = false;
        public bool IsObpUser { get; set; } = false; 
    }

    public class ObpLoginResponse
    {
        public string Token { get; set; }
    }

}
