<div class="card">
    <h4>🧾 Dernières transactions</h4>
    @foreach (var tx in Transactions)
    {
        var cssClass = tx.Amount >= 0 ? "right positive" : "right negative";
        <p>@tx.Date – @tx.Label <span class="@cssClass">@tx.Amount.ToString("C")</span></p>
    }
</div>

@code {
    [Parameter] public List<Home.Transaction> Transactions { get; set; } = [];
}
