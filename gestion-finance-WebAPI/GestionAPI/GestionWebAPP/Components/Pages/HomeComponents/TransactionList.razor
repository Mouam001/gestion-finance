@using Common.DTO
@inject IJSRuntime JSRuntime

<div class="card">
    <h4>🧾 Transactions</h4>

    @if ((Transactions != null && Transactions_.Count > 0))
    {
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-primary " @onclick="DownloadPdfAsync"> Telecharger le pdf</button>
        </div>
        <div class="transaction-table-container">
            <table class="table">
                <thead>
                <tr>
                    
                    <th>Type</th>
                    <th>Description</th>
                    <th>Montant (€)</th>
                </tr>
                </thead>
                <tbody>
                
                @foreach (var tx in Transactions_)
                {
                    var cssClass = tx.Amount >= 0 ? "text-success" : "text-danger";
                    <tr>
                        <td>@tx.Type</td>
                        <td>@tx.Label</td>
                        <td class="@cssClass">@tx.Amount.ToString("F2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else if (Transactions != null && Transactions.Count > 0)
    {
        <div class="card">
            <h4>🧾 Dernières transactions</h4>
            @foreach (var tx in Transactions)
            {
                <p>@tx.CompletedDate.ToString() – @tx.Description 
                    <span class="@GetAmountCssClass(tx.Amount)">
                        @tx.Amount.ToString("C")
                    </span>
                </p>
            }

        </div>
        <style>
    .text-danger {
        color: red;
    }
    
    .text-success {
        color: green;
    }

</style>
    }
    else
    {
        <p>Aucune transaction disponible.</p>
    }
</div>

@code {
    [Parameter] public List<TransactionDto> Transactions { get; set; } = new();
    [Parameter] public List<Home_OBP.Transaction_> Transactions_ { get; set; } = new();
    [Parameter] public string selectBankId { get; set; }
    [Parameter] public string selectAccountId { get; set; }

    
    private string GetAmountCssClass(decimal amount)
    {
        return amount >= 0 ? "text-success" : "text-danger";
    }

    protected override void OnParametersSet()
    {
        JSRuntime.InvokeVoidAsync("console.log", $"Transactions classiques : {System.Text.Json.JsonSerializer.Serialize(Transactions)}");
        JSRuntime.InvokeVoidAsync("console.log", $"Transactions OBP : {System.Text.Json.JsonSerializer.Serialize(Transactions_)}");
    }
    [Inject] private HttpClient Http { get; set; }
    [Inject] private Blazored.LocalStorage.ILocalStorageService LocalStorage { get; set; }

    private async Task DownloadPdfAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("obpToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Console.WriteLine("Token OBP non trouvé");
            return;
        }

        if (string.IsNullOrWhiteSpace(selectBankId) || string.IsNullOrWhiteSpace(selectAccountId))
        {
            Console.WriteLine("Aucune sélection de compte. Veuillez choisir un compte.");
            return;
        }

        Console.WriteLine($"Téléchargement du PDF : BankId={selectBankId}, AccountId={selectAccountId}");

        var request = new HttpRequestMessage(HttpMethod.Get, $"api/obp/pdf-releve/{selectBankId}/{selectAccountId}");
        request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var response = await Http.SendAsync(request);
    
        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine($"❌ Erreur API : {response.StatusCode}");
            return;
        }

        Console.WriteLine($"PDF reçu, lancement du téléchargement !");
        var fileBytes = await response.Content.ReadAsByteArrayAsync();
        var base64 = Convert.ToBase64String(fileBytes);
        await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", base64, "releve-transactions.pdf");
    }

}

