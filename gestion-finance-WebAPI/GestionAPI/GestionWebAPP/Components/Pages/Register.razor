@page "/register"
@using GestionWebAPP.Services
@using Common.Requests
@using System.ComponentModel.DataAnnotations
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS


<Div Margin="Margin.IsAuto.OnX" Width="Width.Is50">
    <Heading Size="HeadingSize.Is2" Margin="Margin.Is3.FromBottom" TextAlignment="TextAlignment.Center">
        Create an account
    </Heading>

    <Card Shadow="Shadow.Default">
        <CardBody>
            <EditForm Model="RegisterModel" OnValidSubmit="OnSubmit">
                
                <Blazorise.ValidationSummary/>

                <Field>
                    <FieldLabel>Your Name</FieldLabel>
                    <div class="input-group">
                        <input type="text" id="firstname" name="firstname" @bind="RegisterModel.Name" placeholder="First Name" >
                        <ValidationMessage For="@(() => RegisterModel.Name)"/>
                    </div>
                    <div class="input-group">
                         <input type="text" id="lastname" name="lastname" @bind="RegisterModel.LastName" placeholder="Last Name" >
                         <ValidationMessage For="@(() => RegisterModel.LastName)"/>
                    </div>
                    
                </Field>

                <Field>
                    <FieldLabel>Your Email</FieldLabel>
                    <div class="input-group">
                        <input type="email" id="mail" name="mail" @bind="RegisterModel.Email" placeholder="name@blazorise.com" >
                        <ValidationMessage For="@(() => RegisterModel.Email)"/>
                    </div>
                </Field>

                <Field>
                    <FieldLabel>Password</FieldLabel>
                    <div class="input-group">
                        <input type="password" id="password" name="password" @bind="RegisterModel.Password" placeholder="********">
                        <ValidationMessage For="@(() => RegisterModel.Password)"/>
                    </div>
                </Field>

                <Field>
                    <FieldLabel>Confirm Password</FieldLabel>
                    <div class="input-group">
                        <input type="password" id="confirmpassword" name="confirmpassword" @bind="RegisterModel.ConfirmPassword" placeholder="********">
                        <ValidationMessage For="@(() => RegisterModel.ConfirmPassword)"/>
                    </div>
                </Field>

                <Field>
                    <FieldLabel>Phone Number</FieldLabel>
                    <div class="input-group">
                        <input type="number" id="phone" name="phone" @bind="RegisterModel.Phone" placeholder="Phone Number">
                        <ValidationMessage For="@(() => RegisterModel.Phone)"/>
                    </div>
                </Field>

                <Field>
                    <FieldLabel>Address</FieldLabel>
                    <div class="input-group">
                        <input type="text" id="adress" name="adress" @bind="RegisterModel.Address" placeholder="Your Adress">
                        <ValidationMessage For="@(() => RegisterModel.Address)"/>
                    </div>
                </Field>

                <Field>
                    <FieldLabel>Initial Balance</FieldLabel>
                    <div class="input-group">
                        <input type="number" id="balance" name="balance" @bind="RegisterModel.BalanceInit" placeholder="Initial Balancer">
                        <ValidationMessage For="@(() => RegisterModel.BalanceInit)"/>
                    </div>
                </Field>

                @if (!string.IsNullOrEmpty(ApiErrorMessage))
                {
                    foreach (var line in ApiErrorMessage.Split('\n'))
                    {
                        <div class="text-danger">@line</div>
                    }
                }

                @if (PasswordMismatchError)
                {
                    <div class="text-danger mt-2">Passwords do not match.</div>
                }

                @if (RegistrationFailed)
                {
                    <div class="text-danger mt-2">Registration failed. Please try again.</div>
                }

                <Field>
                    <Button Color="Color.Primary" Type="@ButtonType.Submit" Block>
                        Create an account
                    </Button>
                </Field>

                <Field>
                    Already have an account? <Anchor To="/login" TextColor="TextColor.Primary">Login here</Anchor>
                </Field>
            </EditForm>
        </CardBody>
    </Card>
</Div>

@code {
    private ModelRegister RegisterModel { get; set; } = new();
    private bool PasswordMismatchError { get; set; } = false;
    private bool RegistrationFailed { get; set; } = false;

    private string ApiErrorMessage { get; set; } = "";

    private async Task OnSubmit()
    {

        ApiErrorMessage = "";
        PasswordMismatchError = RegisterModel.Password != RegisterModel.ConfirmPassword;

        if (PasswordMismatchError)
            return;

        var registerRequest = new RegisterRequest
        {
            Email = RegisterModel.Email,
            Password = RegisterModel.Password,
            ConfirmPassword = RegisterModel.ConfirmPassword,
            Name = RegisterModel.Name,
            LastName = RegisterModel.LastName,
            Phone = RegisterModel.Phone,
            Address = RegisterModel.Address,
            BalanceInit = RegisterModel.BalanceInit
        };
        await JS.InvokeVoidAsync("console.log", $"Name: {registerRequest.Name}, Email: {registerRequest.Email}, Password: {registerRequest.Password},Balance:{registerRequest.ConfirmPassword}");


        var result = await AuthService.Register(registerRequest);

        if (result.IsSuccess)
        {
            Navigation.NavigateTo("/login");
        }
        else
        {
            ApiErrorMessage = result.ErrorMessage ?? "Registration failed. Please try again.";
            RegistrationFailed = true;
        }
    }

    public class ModelRegister
    {
        // Validation minimale : juste s'assurer que les champs ne sont pas vides
        [Required(ErrorMessage = "First name is required.")]
        public string Name { get; set; } = ""; 

        [Required(ErrorMessage = "Last name is required.")]
        public string LastName { get; set; } = ""; 

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirm password is required.")]
        [Compare("Password", ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";

        [Required(ErrorMessage = "Phone number is required.")]
        public int Phone { get; set; } = 0;

        [Required(ErrorMessage = "Address is required.")]
        public string Address { get; set; } = "";

        [Required(ErrorMessage = "Balance is required.")]
        [Range(0.01, float.MaxValue, ErrorMessage = "Balance must be a positive number.")]
        public float BalanceInit { get; set; } = 0;
    }
}
